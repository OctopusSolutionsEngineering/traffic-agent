variable "Runbook.TestAgent.Prompt" {
    value "Is AA1019 on time?" {
        process = ["runbook/test-agent"]

        prompt {
            description = ""
            display_settings = {
                Octopus.ControlType = "SingleLineText"
            }
            label = "Prompt"
        }
    }
}

variable "config:sentinel" {
    value "v1" {}
}

variable "config:openai:model" {
    value "gpt-4o-mini" {}
}

variable "config:log-level" {
    value "INFO" {}
}

variable "config:cache:ttl:geocoding" {
    value "86400" {}
}

variable "config:cache:ttl:forecast" {
    value "1800" {}
}

variable "config:cache:ttl:current-weather" {
    value "600" {}
}

variable "config:cache:ttl:agent-response" {
    value "300" {}
}

variable "config:cache:redis-url" {
    value "redis://redis.flight-agent.flight-agent-production.svc.cluster.local:6379/0" {
        environment = ["production"]
    }

    value "redis://redis.flight-agent.flight-agent-qa.svc.cluster.local:6379/0" {
        description = ""
        environment = ["qa"]
    }

    value "redis://redis.flight-agent.flight-agent-development.svc.cluster.local:6379/0" {
        description = ""
        environment = ["development"]
    }
}

variable "config:cache:backend" {
    value "redis" {}
}
